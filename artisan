def route():
    """Route management commands."""
    pass


@route.command(name='list')
@click.option('--method', help='Filter by HTTP method')
@click.option('--name', help='Filter by route name')
def list_routes(method, name):
    """List all registered routes."""
    click.echo("📋 Registered Routes:")
    click.echo("")
    click.echo("Method | URI | Name | Action")
    click.echo("-------|-----|------|--------")
    
    try:
        from app.Foundation.Application import app
        routes = app.resolve('router').get_routes()
        
        for route in routes:
            http_method = getattr(route, 'method', 'GET')
            uri = getattr(route, 'path', '/')
            route_name = getattr(route, 'name', 'unnamed')
            action = getattr(route, 'endpoint', 'unknown')
            
            # Apply filters
            if method and http_method.upper() != method.upper():
                continue
            if name and route_name != name:
                continue
                
            click.echo(f"{http_method:<6} | {uri:<20} | {route_name:<20} | {action}")
    except Exception as e:
        click.echo(f"❌ Error listing routes: {str(e)}")
        # Fallback to sample routes
        sample_routes = [
            ("GET", "/", "home", "HomeController@index"),
            ("GET", "/about", "about", "HomeController@about"),
            ("GET", "/api/v1/users", "api.users.index", "UserController@index"),
            ("POST", "/api/v1/users", "api.users.store", "UserController@store"),
        ]
        
        for http_method, uri, route_name, action in sample_routes:
        if method and http_method.lower() != method.lower():
            continue
        if name and name not in route_name:
            continue
        click.echo(f"{http_method:<6} | {uri:<15} | {route_name:<20} | {action}")


