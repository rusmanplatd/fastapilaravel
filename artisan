    FastAPI Laravel Artisan Console.
    
    Welcome to the FastAPI Laravel application console! This tool provides
    a powerful set of commands to help you manage your application.
    """
    if ctx.invoked_subcommand is None:
        click.echo("🚀 FastAPI Laravel Artisan Console")
        click.echo("")
        click.echo("Available commands:")
        click.echo("  inspire        Display an inspiring quote")
        click.echo("  make           Generate code (controllers, models, etc.)")
        click.echo("  serve          Start the development server")
        click.echo("  migrate        Run database migrations")
        click.echo("  seed           Seed the database with sample data")
        click.echo("  queue:work     Start processing queue jobs")
        click.echo("  route:list     List all registered routes")
        click.echo("  config:cache   Cache the configuration files")
        click.echo("  config:clear   Clear the configuration cache")
        click.echo("  key:generate   Generate a new application key")
        click.echo("")
        click.echo("Use 'artisan <command> --help' for more information about a command.")


