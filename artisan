@cli.command()
@click.option('--host', default='0.0.0.0', help='Host to bind to')
@click.option('--port', default=8000, help='Port to bind to')
@click.option('--reload', is_flag=True, help='Enable auto-reload')
@click.option('--debug', is_flag=True, help='Enable debug mode')
def serve(host, port, reload, debug):
    """Start the development server."""
    click.echo(f"🚀 Starting FastAPI Laravel development server...")
    click.echo(f"📍 Server will be available at: http://{host}:{port}")
    click.echo(f"📖 API documentation at: http://{host}:{port}/docs")
    click.echo("")
    
    import uvicorn
    
    # Set environment variables if debug is enabled
    if debug:
        os.environ['APP_DEBUG'] = 'true'
        os.environ['APP_ENV'] = 'local'
    
    try:
        uvicorn.run(
            "main:app",
            host=host,
            port=port,
            reload=reload or debug,
            log_level="debug" if debug else "info"
        )
    except KeyboardInterrupt:
        click.echo("\n🛑 Server stopped.")


@cli.command()
@click.option('--fresh', is_flag=True, help='Drop all tables and re-run all migrations')
@click.option('--seed', is_flag=True, help='Seed the database after running migrations')
def migrate(fresh, seed):
    """Run database migrations."""
    click.echo("🗄️  Running database migrations...")
    
    if fresh:
        click.echo("⚠️  Dropping all tables...")
        try:
            from database.migrations.MigrationRunner import MigrationRunner
            runner = MigrationRunner()
            runner.drop_all_tables()
            click.echo("✅ All tables dropped.")
        except Exception as e:
            click.echo(f"❌ Error dropping tables: {str(e)}")
    
    try:
        from database.migrations.MigrationRunner import MigrationRunner
        runner = MigrationRunner()
        runner.run_migrations()
        click.echo("✅ Migrations completed successfully.")
    except Exception as e:
        click.echo(f"❌ Migration error: {str(e)}")
    
    if seed:
        click.echo("🌱 Seeding database...")
        try:
            from database.seeders.DatabaseSeeder import DatabaseSeeder
            seeder = DatabaseSeeder()
            seeder.run()
            click.echo("✅ Database seeding completed.")
        except Exception as e:
            click.echo(f"❌ Seeding error: {str(e)}")


@cli.command()
@click.option('--class', 'seeder_class', help='Specific seeder class to run')
def seed(seeder_class):
    """Seed the database with sample data."""
    try:
        if seeder_class:
            click.echo(f"🌱 Running seeder: {seeder_class}")
            # Import and run specific seeder
            from importlib import import_module
            seeder_module = import_module(f"database.seeders.{seeder_class}")
            seeder = getattr(seeder_module, seeder_class)()
            seeder.run()
        else:
            click.echo("🌱 Seeding database with sample data...")
            from database.seeders.DatabaseSeeder import DatabaseSeeder
            seeder = DatabaseSeeder()
            seeder.run()
        
        click.echo("✅ Database seeding completed.")
    except Exception as e:
        click.echo(f"❌ Seeding error: {str(e)}")


@cli.group(name='queue')
def queue():
    """Queue management commands."""
    pass


@queue.command()
@click.option('--queue', default='default', help='Queue name to process')
@click.option('--timeout', default=60, help='Worker timeout in seconds')
@click.option('--sleep', default=3, help='Sleep time between jobs in seconds')
@click.option('--tries', default=3, help='Number of attempts for failed jobs')
def work(queue, timeout, sleep, tries):
    """Start processing queue jobs."""
    click.echo(f"🔄 Starting queue worker for '{queue}' queue...")
    click.echo(f"⏱️  Timeout: {timeout}s, Sleep: {sleep}s, Max tries: {tries}")
    click.echo("Press Ctrl+C to stop the worker.")
    
    try:
        from app.Queue.Worker.QueueWorker import QueueWorker
        worker = QueueWorker(
            queue_name=queue,
            timeout=timeout,
            sleep_duration=sleep,
            max_tries=tries
        )
        worker.start()
    except KeyboardInterrupt:
        click.echo("\n👋 Queue worker stopped.")
    except Exception as e:
        click.echo(f"❌ Queue worker error: {str(e)}")
    try:
        import time
        while True:
            click.echo("Processing jobs...")
            time.sleep(sleep)
    except KeyboardInterrupt:
        click.echo("\n🛑 Queue worker stopped.")


