@cli.group(name='key')
def key():
    """Application key management commands."""
    pass


@key.command()
@click.option('--show', is_flag=True, help='Display the key instead of modifying files')
def generate(show):
    """Generate a new application key."""
    import secrets
    import string
    
    # Generate a 32-character random key
    alphabet = string.ascii_letters + string.digits
    new_key = ''.join(secrets.choice(alphabet) for _ in range(32))
    
    if show:
        click.echo(f"Application key: {new_key}")
    else:
        click.echo("🔑 Generating application key...")
        
        try:
            import os
            from pathlib import Path
            
            env_file = Path('.env')
            if env_file.exists():
                content = env_file.read_text()
                if 'APP_KEY=' in content:
                    # Replace existing key
                    import re
                    content = re.sub(r'APP_KEY=.*', f'APP_KEY={new_key}', content)
                else:
                    # Add new key
                    content += f'\nAPP_KEY={new_key}\n'
                
                env_file.write_text(content)
                click.echo(f"✅ Application key set to: {new_key}")
            else:
                click.echo(f"⚠️  .env file not found. Generated key: {new_key}")
                click.echo("💡 Create a .env file and add APP_KEY={new_key}")
        except Exception as e:
            click.echo(f"❌ Error updating .env file: {str(e)}")
            click.echo(f"💡 Generated key: {new_key}")


@cli.command()
def tinker():
    """Start an interactive Python shell."""
    click.echo("🐍 Starting FastAPI Laravel interactive shell...")
    click.echo("Available objects: app, models")
    
    # Create application context
    app = create_application()
    
    import code
    
    # Import all models dynamically
    models = {}
    try:
        from app.Models import User, Role, Permission, OAuth2Client, OAuth2AccessToken
        from app.Models import ChatRoom, Order, JobBatch, Job, Notification
        models.update({
            'User': User,
            'Role': Role, 
            'Permission': Permission,
            'OAuth2Client': OAuth2Client,
            'OAuth2AccessToken': OAuth2AccessToken,
            'ChatRoom': ChatRoom,
            'Order': Order,
            'JobBatch': JobBatch,
            'Job': Job,
            'Notification': Notification
        })
    except ImportError as e:
        click.echo(f"⚠️  Some models could not be imported: {e}")
    
    namespace = {
        'app': app,
        'models': models,
    }
    
    code.interact(local=namespace)


